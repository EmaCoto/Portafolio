---
const {
  className = "",
  size = 260,
  strokeWidth = 3,
} = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" 
    class={`arrow-trending-up-icon ${className}`}
    data-animated="true"
    width={size}
    height={size}
    fill="none" 
    viewBox="0 0 24 24" 
    stroke-width="1.5" 
    role="img"
    aria-label="Arrow trending up icon"
>
    <path class="draw" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
        stroke="#72bf78"
        stroke-width={strokeWidth}
        stroke-linecap="round"
        stroke-linejoin="round"
    />
</svg>

<script>
  function initTrendingAnimation() {
    // Captura cualquier SVG animado de forma global en la página actual
    const icons = document.querySelectorAll<SVGSVGElement>('svg[data-animated="true"]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const icon = entry.target as SVGSVGElement;
          const paths = icon.querySelectorAll<SVGGeometryElement>('.draw');

          paths.forEach((path) => {
            const length = path.getTotalLength();
            path.style.strokeDasharray = `${length}`;
            path.style.strokeDashoffset = `${length}`;
          });

          icon.classList.add('is-visible');
          observer.unobserve(icon);
        }
      });
    }, {
      threshold: 0.5
    });

    icons.forEach((icon) => observer.observe(icon));
  }

  // Escucha los eventos de ciclo de vida nativos de Astro
  document.addEventListener('DOMContentLoaded', initTrendingAnimation);
  document.addEventListener('astro:page-load', initTrendingAnimation);
</script>

<style>
  .arrow-trending-up-icon {
    display: block;
    overflow: visible;
  }

  .arrow-trending-up-icon.is-visible .draw {
    animation-name: drawLine;
    animation-duration: 4s;
    animation-timing-function: ease;
    animation-fill-mode: forwards;
    animation-delay: 1s;
  }

  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow-trending-up-icon .draw {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>