---
const {
  className = "",
  size = 260,
  strokeWidth = 3,
} = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" 
    class={`heart-icon ${className}`}
    data-animated="true"
    width={size}
    height={size}
    fill="none" 
    viewBox="0 0 24 24" 
    stroke-width="1.5" 
    role="img"
    aria-label="Heart icon"
>
    <path class="draw" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"
        stroke="#72bf78"
        stroke-width={strokeWidth}
        stroke-linecap="round"
        stroke-linejoin="round"
    />
</svg>

<script>
  function initHeartAnimation() {
    // Busca de forma global cualquier SVG con animación habilitada en el DOM actual
    const icons = document.querySelectorAll<SVGSVGElement>('svg[data-animated="true"]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const icon = entry.target as SVGSVGElement;
          const paths = icon.querySelectorAll<SVGGeometryElement>('.draw');

          paths.forEach((path) => {
            const length = path.getTotalLength();
            path.style.strokeDasharray = `${length}`;
            path.style.strokeDashoffset = `${length}`;
          });

          icon.classList.add('is-visible');
          observer.unobserve(icon);
        }
      });
    }, {
      threshold: 0.5
    });

    icons.forEach((icon) => observer.observe(icon));
  }

  // Se activa tanto en la carga inicial como en las transiciones de página (Router/ClientRouter) de Astro
  document.addEventListener('DOMContentLoaded', initHeartAnimation);
  document.addEventListener('astro:page-load', initHeartAnimation);
</script>

<style>
  .heart-icon {
    display: block;
    overflow: visible;
  }

  .heart-icon.is-visible .draw {
    animation-name: drawLine;
    animation-duration: 4s;
    animation-timing-function: ease;
    animation-fill-mode: forwards;
    animation-delay: 1s;
  }

  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .heart-icon .draw {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>