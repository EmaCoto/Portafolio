---
const {
  className = "",
  size = 260,
  strokeWidth = 3,
} = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" 
    class={`arrow-right-icon ${className}`}
    data-animated="true"
    width={size}
    height={size}
    fill="none" 
    viewBox="0 0 24 24" 
    stroke-width="1.5" 
    role="img"
    aria-label="Arrow right icon"
>
    <path class="draw" d="m12.75 15 3-3m0 0-3-3m3 3h-7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" 
        stroke="#72bf78"
        stroke-width={strokeWidth}
        stroke-linecap="round"
        stroke-linejoin="round"
    />
</svg>

<script>
  function initArrowAnimation() {
    // Selector global para capturar este componente en cualquier página
    const icons = document.querySelectorAll<SVGSVGElement>('svg[data-animated="true"]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const icon = entry.target as SVGSVGElement;
          const paths = icon.querySelectorAll<SVGGeometryElement>('.draw');

          paths.forEach((path) => {
            const length = path.getTotalLength();
            path.style.strokeDasharray = `${length}`;
            path.style.strokeDashoffset = `${length}`;
          });

          icon.classList.add('is-visible');
          observer.unobserve(icon);
        }
      });
    }, {
      threshold: 0.5
    });

    icons.forEach((icon) => observer.observe(icon));
  }

  // Ejecuta en carga inicial y al navegar entre páginas de Astro
  document.addEventListener('DOMContentLoaded', initArrowAnimation);
  document.addEventListener('astro:page-load', initArrowAnimation);
</script>

<style>
  .arrow-right-icon {
    display: block;
    overflow: visible;
  }

  .arrow-right-icon.is-visible .draw {
    animation-name: drawLine;
    animation-duration: 4s;
    animation-timing-function: ease;
    animation-fill-mode: forwards;
    animation-delay: 1s;
  }

  @keyframes drawLine {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .arrow-right-icon .draw {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>